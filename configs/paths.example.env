# PairUAV / VGGT 路径示例。请按本机环境设置这些变量。

export VGGT_WEIGHT=/path/to/vggt/model.pt
export PAIRUAV_ALL_TRAIN_JSON=/path/to/pairuav/train/json
export PAIRUAV_TRAIN_JSON=/path/to/pairuav/train/json
export PAIRUAV_VAL_JSON=/path/to/pairuav/val/json
export PAIRUAV_TRAIN_IMAGES=/path/to/pairuav/train/images
export PAIRUAV_TEST_JSON=/path/to/pairuav/test/json
export PAIRUAV_TEST_IMAGES=/path/to/pairuav/test/images
export PAIRUAV_CACHE_ROOT=/path/to/cache/root
export PAIRUAV_RUN_ROOT=/path/to/run/root
export PAIRUAV_RELEASE_BUNDLE=/path/to/released/checkpoints-and-submissions

# 一键脚本的可选覆盖。默认值分别为仓库内 artifacts/competition_submission 和时间戳输出目录。
# export PAIRUAV_SUBMISSION_ASSETS=/path/to/artifacts/competition_submission
# export PAIRUAV_SUBMISSION_CACHE=/path/to/artifacts/competition_submission/cache/test_pairs_s518
# export PAIRUAV_SUBMISSION_RUN_DIR=/path/to/output/submission_reproduction

# 已有 cache 时设置这两个变量可跳过 VGGT;两者必须同时设置且必须与所传 index 顺序一致。
# export PAIRUAV_TRAIN_CACHE=/path/to/cache/train_balanced_32768
# export PAIRUAV_VAL_CACHE=/path/to/cache/val_quick_2048
